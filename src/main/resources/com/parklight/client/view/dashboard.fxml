<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.parklight.client.controller.DashboardController">
    <top>
        <VBox spacing="4.0" style="-fx-padding: 12;">
            <Label text="ParkLight Dashboard" style="-fx-font-size: 20px; -fx-font-weight: bold;"/>
            <Label fx:id="statusLabel" text="Loading..."/>
        </VBox>
    </top>
    <center>
        <TableView fx:id="spotsTable">
            <columns>
                <TableColumn fx:id="idColumn" text="Spot" prefWidth="200"/>
                <TableColumn fx:id="typeColumn" text="Type" prefWidth="220"/>
                <TableColumn fx:id="statusColumn" text="Status" prefWidth="220"/>
            </columns>
        </TableView>
    </center>
    <bottom>
        <HBox spacing="8.0" style="-fx-padding: 12;">
            <Button text="Refresh" onAction="#refresh"/>
            <Button text="Park Vehicle" onAction="#goPark"/>
            <Button text="Release Vehicle" onAction="#goRelease"/>
        </HBox>
    </bottom>
</BorderPane>
