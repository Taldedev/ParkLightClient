<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Separator?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.parklight.client.controller.ReleaseController">
    <top>
        <Label text="Release a Vehicle"
               style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-padding: 12;"/>
    </top>
    <center>
        <VBox spacing="12.0" style="-fx-padding: 20;">
            <Label text="Ticket id:"/>
            <TextField fx:id="ticketField" promptText="paste the ticket id"/>
            <Button text="Release" onAction="#release"/>
            <Label fx:id="releaseLabel" style="-fx-font-weight: bold;"/>
            <Separator/>
            <Button text="Show Total Revenue" onAction="#showRevenue"/>
            <Label fx:id="revenueLabel" style="-fx-font-weight: bold;"/>
        </VBox>
    </center>
    <bottom>
        <HBox spacing="8.0" style="-fx-padding: 12;">
            <Button text="Back" onAction="#back"/>
        </HBox>
    </bottom>
</BorderPane>
