<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.parklight.client.controller.ReleaseController">
    <top>
        <Label text="Release a Vehicle"
               style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-padding: 12;"/>
    </top>
    <center>
        <VBox spacing="10.0" style="-fx-padding: 16;">
            <Label text="Currently parked vehicles (select one):"/>
            <TableView fx:id="activeTable" prefHeight="220">
                <columns>
                    <TableColumn fx:id="plateColumn" text="License Plate" prefWidth="180"/>
                    <TableColumn fx:id="spotColumn" text="Spot" prefWidth="100"/>
                    <TableColumn fx:id="ticketColumn" text="Ticket" prefWidth="320"/>
                </columns>
            </TableView>
            <HBox spacing="8.0">
                <Button text="Release Selected" onAction="#release"/>
                <Button text="Refresh List" onAction="#loadActive"/>
            </HBox>
            <Label fx:id="releaseLabel" style="-fx-font-weight: bold;"/>
            <Separator/>
            <HBox spacing="8.0">
                <Button text="Show Total Revenue" onAction="#showRevenue"/>
                <Button text="Cash Out" onAction="#cashOut"/>
                <Button text="Cash Out History" onAction="#goHistory"/>
            </HBox>
            <Label fx:id="revenueLabel" style="-fx-font-weight: bold;"/>
        </VBox>
    </center>
    <bottom>
        <HBox spacing="8.0" style="-fx-padding: 12;">
            <Button text="Back" onAction="#back"/>
        </HBox>
    </bottom>
</BorderPane>
